            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status Code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response Time Less Than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content Type Validation\", function () {\r",
                  "    pm.expect(\r",
                  "        pm.response.headers.get(\"Content-Type\")\r",
                  "    ).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "var response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Token Generated\", function () {\r",
                  "    pm.expect(response.token).to.not.be.null;\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\r",
                  "    \"token\",\r",
                  "    response.token\r",
                  ");"
